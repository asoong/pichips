# PiChip Viewer Configuration
# Copy this file to .env and adjust values as needed

# Video stream source (Raspberry Pi)
PICHIP_STREAM_URL=tcp://pichip.local:8888

# Custom detector trained from a PiChip training-set export (see train.py / TRAINING.md).
# This is the model overlay_viewer.py loads by default.
PICHIP_DETECTOR_PATH=models/pichip_detector.pt

# Streamlit debug app model path. Defaults to the custom detector; point it at a
# *-worldv2.pt file to use open-vocab YOLO-World mode instead.
PICHIP_YOLO_PATH=models/pichip_detector.pt

# Detection tuning
PICHIP_DETECT_INTERVAL=5
PICHIP_CONFIDENCE=0.3

# Device selection: auto, cuda, mps, cpu
PICHIP_DEVICE=auto
