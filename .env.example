# PiChip Viewer Configuration
# Copy this file to .env and adjust values as needed

# Frame source:
#   picamera2 = capture the Pi's CSI camera directly (viewer runs ON the Pi)
#   stream    = pull a remote TCP feed from PICHIP_STREAM_URL (viewer runs elsewhere)
# Leave blank to auto-detect (uses the Pi camera when picamera2 is available).
PICHIP_SOURCE=picamera2

# Remote video stream source, used only when PICHIP_SOURCE=stream.
PICHIP_STREAM_URL=tcp://pichip.local:8888

# Stream the annotated feed as MJPEG-over-HTTP on this port (0/unset = off). Lets another
# machine watch the live detection in a browser at http://<pi-host>:<port>/ — ideal when
# the Pi runs headless over SSH. Works alongside a local monitor.
PICHIP_MJPEG_PORT=8090

# Custom detector trained from a PiChip training-set export (see train.py / TRAINING.md).
# This is the model overlay_viewer.py loads by default.
PICHIP_DETECTOR_PATH=models/pichip_detector.pt

# Streamlit debug app model path. Defaults to the custom detector; point it at a
# *-worldv2.pt file to use open-vocab YOLO-World mode instead.
PICHIP_YOLO_PATH=models/pichip_detector.pt

# Detection tuning
PICHIP_DETECT_INTERVAL=5
PICHIP_CONFIDENCE=0.3

# Device selection: auto, cuda, mps, cpu
PICHIP_DEVICE=auto
