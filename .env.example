# PiChip Viewer Configuration
# Copy this file to .env and adjust values as needed

# Video stream source (Raspberry Pi)
PICHIP_STREAM_URL=tcp://pichip.local:8888

# Model paths (relative to project root)
PICHIP_MOBILESAM_PATH=models/mobile_sam.pt
PICHIP_YOLO_PATH=models/yolov8s-worldv2.pt

# Performance tuning
PICHIP_SAM_INTERVAL=10
PICHIP_MIN_REGION_AREA=1000

# Device selection: auto, cuda, mps, cpu
PICHIP_DEVICE=auto
